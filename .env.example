# ── 필수 ──
GEMINI_API_KEY=your-gemini-api-key

# ── 선택 ──
# 멀티유저 PIN (format: PIN:이름,PIN:이름)
# APP_PINS=123456:아내,789012:남편

# 쿠키 서명 시크릿 (미설정 시 기본값 사용)
# SESSION_SECRET=change-this-to-a-random-secret

# 세션 유효기간 (일, 기본: 7)
# SESSION_DAYS=7

# 웹훅 HMAC 검증 시크릿 (미설정 시 검증 스킵)
# WEBHOOK_SECRET=change-this-to-match-android-app

# DB 경로 (기본: sqlite:///ledger.db)
# DATABASE_URL=sqlite:///ledger.db
